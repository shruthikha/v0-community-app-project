# Río Agent — Environment Variables
# Copy this file to .env for local development
# Set these variables in Railway → Service → Variables for production

# ─── LLM Gateway ───────────────────────────────────────────────────────────
# Primary LLM provider via OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Supabase ───────────────────────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — admin access, never expose to browser
# Found in Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# PostgreSQL connection string (Transaction Pooler - port 6543)
# Format: postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres
DATABASE_URL=

# ─── Runtime ────────────────────────────────────────────────────────────────
# Set to 'production' in Railway; 'development' locally
NODE_ENV=development

# PORT is assigned automatically by Railway — do NOT set this in Railway Variables
# For local development, defaults to 3001 (to avoid conflict with Next.js on 3000)
PORT=3001

# ─── Llama Cloud (Ingestion Phase — Sprint 9) ──────────────────────────────
# Used for high-fidelity document parsing via LlamaParse
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# ─── Observability (Sprint 7 Issue #171) ────────────────────────────────────
# PostHog configuration for trace and event logging
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://us.i.posthog.com
